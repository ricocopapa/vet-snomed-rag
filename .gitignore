# ── Project Data (large, regeneratable) ──────────────
# NOTE: git cannot un-ignore children of an ignored directory.
# Strategy: ignore data/ subdirectories selectively, not the parent.
# Public items: data/synthetic_scenarios/, data/mrcm_rules_v1.json, data/field_schema_v26.json
# Private items (patient DB, chroma index, audio): explicitly blocked below.
data/chroma_db/
data/chroma_db_baseline_minilm/
data/chroma_phase2_*/
data/synthetic_scenarios/*.mp3
data/*.db
data/*.sqlite
data/*.sqlite3

# ── Private data symlinks (point to local personal workspace) ────
# These files are symlinks to ~/claude-cowork/05_Output_Workspace/ on the maintainer's machine.
# They expose private paths and reference patient-derived mappings not licensed for redistribution.
data/assessment_snomed_mapping.json
data/plan_snomed_mapping.json
data/snomed_mapping_v2.json
data/snomed_post_coord_rules.json
data/index_stats.json

# ── Personal tooling (contains hardcoded local paths) ────────────
scripts/dump_field_schema.py

# ── SNOMED CT-Derived Content (license-restricted redistribution) ─
# Excluded from public repo due to SNOMED International licensing constraints.
# End users must obtain SNOMED CT under their national affiliate licence,
# then regenerate these files locally via the pipeline.
docs/snomed_graph/
docs/snomed_graph_v2/

