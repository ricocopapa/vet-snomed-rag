{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "A2A Message",
  "description": "Agent-to-Agent Protocol 메시지 스키마 (Google A2A 2025-04 기반)",
  "type": "object",
  "required": ["message_id", "sender", "receiver", "intent", "payload", "deadline"],
  "properties": {
    "message_id": {
      "type": "string",
      "format": "uuid",
      "description": "메시지 고유 식별자 (UUID v4)"
    },
    "sender": {
      "type": "string",
      "description": "송신 에이전트 식별자",
      "examples": ["claude_reviewer@v2.1", "gemini_independent_judge@flash-lite-3.1"]
    },
    "receiver": {
      "type": "string",
      "description": "수신 에이전트 식별자"
    },
    "intent": {
      "type": "string",
      "enum": ["request", "response", "negotiate", "report", "error"],
      "description": "메시지 의도 분류"
    },
    "payload": {
      "type": "object",
      "description": "메시지 본문 (intent별 스키마 상이)",
      "additionalProperties": true
    },
    "deadline": {
      "type": "string",
      "format": "date-time",
      "description": "수신자가 응답해야 할 마감 시각 (ISO 8601 UTC)"
    },
    "retry_count": {
      "type": "integer",
      "default": 0,
      "minimum": 0,
      "description": "재시도 횟수 (3 초과 시 dead_letter 이동)"
    },
    "correlation_id": {
      "type": "string",
      "description": "스레드 추적용 (request-response 페어링)"
    },
    "ts": {
      "type": "string",
      "format": "date-time",
      "description": "메시지 생성 시각 (ISO 8601 UTC)"
    },
    "signature": {
      "type": "string",
      "description": "송신 에이전트 서명 (선택, 무결성 검증용)"
    }
  }
}
