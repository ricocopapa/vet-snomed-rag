# vet-snomed-rag 환경변수 템플릿
# 사용법: 이 파일을 `.env`로 복사한 뒤 실제 키 값을 채워 넣는다.
#     cp .env.example .env

# ── [필수] Gemini 2.5 Flash API 키 ──────────────────────
# 발급: https://aistudio.google.com/apikey
# 형식: AIza로 시작하는 39자
GOOGLE_API_KEY=your_gemini_api_key_here

# ── [선택] Anthropic Claude API 키 ───────────────────────
# 발급: https://console.anthropic.com/settings/keys
# 형식: sk-ant-로 시작
# A/B 비교 테스트 원할 때만 설정. 빈 값이면 Gemini만 실행.
ANTHROPIC_API_KEY=

# ── [선택, v2.5 Tier B] UMLS REST API 키 ─────────────────
# 발급: https://uts.nlm.nih.gov/uts/signup-login
#   1. UMLS Affiliate License 신청 (한국 회원국 무료, 1~3 영업일 승인)
#   2. UTS 로그인 → My Profile → Edit Profile → "Generate new API Key" 체크 → Save Profile
#   3. 표시된 키 복사
# 형식: 36자 UUID (예: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx)
# 비어있으면 v2.5 Agentic RAG의 UMLS cross-walk 기능 자동 비활성.
UMLS_API_KEY=

# ── [선택, v2.5 Tier B] NCBI E-utilities API 키 ──────────
# 발급: https://www.ncbi.nlm.nih.gov/account/ → Account Settings → API Key Management
#   1. NCBI 계정 (Google SSO 가능)
#   2. "Create an API Key" 즉시 발급
# 형식: 36자 hex
# 비어있으면 PubMed 호출 가능하나 rate limit 3 rps. 키 있으면 10 rps.
NCBI_API_KEY=
